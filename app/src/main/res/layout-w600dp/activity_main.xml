<?xml version="1.0" encoding="utf-8"?>
<!--
  宽屏/平板布局：左右双栏常驻（品牌栏由 BookListFragment header 承担）
  左侧固定显示导航面板（书籍/章节列表）
  右侧显示编辑器内容
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:fitsSystemWindows="true">

    <!-- 左侧导航面板（固定宽度）-->
    <FrameLayout
        android:id="@+id/nav_panel_container"
        android:layout_width="@dimen/nav_panel_width"
        android:layout_height="match_parent"
        android:background="@color/nav_panel_bg"
        android:elevation="2dp"/>

    <!-- 分割线 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/divider"/>

    <!-- 右侧内容/编辑区 -->
    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/surface">

        <!-- 未选中书籍时的占位提示 -->
        <LinearLayout
            android:id="@+id/empty_detail_hint"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.45">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_open_in_new"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="从左侧选择书籍开始写作"
                android:textSize="15sp"
                android:textColor="@color/on_surface"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
