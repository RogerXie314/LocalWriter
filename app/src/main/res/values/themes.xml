<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LocalWriter" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <!--
            打孔屏 / 刘海屏适配：内容延伸到挖孔区域两侧，避免在荣耀 Magic / 小米等
            打孔屏手机上内容被安全区域缩得过小（shortEdges = 短边允许延伸）。
            对所有 Activity 生效，无需逐 Activity 单独声明。
        -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!--
            targetSdk 35+ 会强制应用进入 edge-to-edge 模式，导致内容绘制到状态栏后面。
            此选项选择退出强制 edge-to-edge，确保内容不会被系统栏遮挡。
        -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>

    <!-- 编辑器沉浸主题（继承基础主题，shortEdges 已在基础主题声明）-->
    <style name="Theme.LocalWriter.Editor" parent="Theme.LocalWriter">
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- 认证界面（温暖米色背景）
         强制浅色文字方案：auth_bg 是固定米色，不随系统深色模式变化，
         必须始终使用深色文字以确保可见性。 -->
    <style name="Theme.LocalWriter.Auth" parent="Theme.LocalWriter">
        <item name="android:windowBackground">@color/auth_bg</item>
        <!-- 强制深色文字 -->
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <!-- 禁止系统自动深色变换（API 29+），避免白底转黑后米色背景上出现白字 -->
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <!-- ── 主题皮肤变体 ─────────────────────────────────────────── -->

    <!-- 深蓝文墨 -->
    <style name="Theme.LocalWriter.Blue" parent="Theme.LocalWriter">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryVariant">#0D47A1</item>
        <item name="colorSecondary">#42A5F5</item>
        <item name="android:statusBarColor">#0D47A1</item>
    </style>
    <style name="Theme.LocalWriter.Blue.Editor" parent="Theme.LocalWriter.Blue">
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- 翠竹青绿 -->
    <style name="Theme.LocalWriter.Green" parent="Theme.LocalWriter">
        <item name="colorPrimary">#2E7D32</item>
        <item name="colorPrimaryVariant">#1B5E20</item>
        <item name="colorSecondary">#66BB6A</item>
        <item name="android:statusBarColor">#1B5E20</item>
    </style>
    <style name="Theme.LocalWriter.Green.Editor" parent="Theme.LocalWriter.Green">
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- 深夜暗黑 -->
    <style name="Theme.LocalWriter.Dark" parent="Theme.LocalWriter">
        <item name="colorPrimary">#212121</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorSecondary">#BDBDBD</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowBackground">#121212</item>
    </style>
    <style name="Theme.LocalWriter.Dark.Editor" parent="Theme.LocalWriter.Dark">
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- 玫瑰紫红 -->
    <style name="Theme.LocalWriter.Rose" parent="Theme.LocalWriter">
        <item name="colorPrimary">#AD1457</item>
        <item name="colorPrimaryVariant">#880E4F</item>
        <item name="colorSecondary">#F06292</item>
        <item name="android:statusBarColor">#880E4F</item>
    </style>
    <style name="Theme.LocalWriter.Rose.Editor" parent="Theme.LocalWriter.Rose">
        <item name="android:windowFullscreen">false</item>
    </style>

</resources>
