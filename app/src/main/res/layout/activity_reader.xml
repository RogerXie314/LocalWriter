<?xml version="1.0" encoding="utf-8"?>
<!--
  阅读器根布局（FrameLayout，成熟产品方案）：
  - PagedTextView 占满全屏，contentPaddingTop/Bottom 内边距由代码从 WindowInsets 一次性设定，永不改变
  - 顶部/底部信息栏、工具栏、控制面板均为纯覆盖层（elevation 高于 PagedTextView）
  - 覆盖层的 visibility/translationY 变化完全不影响 PagedTextView 的尺寸/分页
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/readerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── 正文区域（全屏固定，永不受其他 View 影响） ── -->
    <com.localwriter.ui.reader.PagedTextView
        android:id="@+id/pagedTextView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── 书签指示器（覆盖层，右上角） ── -->
    <ImageView
        android:id="@+id/ivBookmarkIndicator"
        android:layout_width="28dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="64dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_bookmark"
        android:tint="#66888888"
        android:elevation="6dp"
        android:contentDescription="书签" />


    <!--
      沉浸顶部信息栏：[返回] [书名] [电量] [时间]
      高度由代码设定 = statusBarHeight + 44dp（与 contentPaddingTop 完全一致）
      翻页模式下始终可见；切换到工具栏模式时 visibility=GONE
    -->
    <LinearLayout
        android:id="@+id/immersiveHeaderBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivImmersiveBack"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="fitCenter"
            android:alpha="0.65"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/tvImmersiveChapterHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:alpha="0.65" />

        <TextView
            android:id="@+id/tvImmersiveBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:alpha="0.65"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvImmersiveTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:alpha="0.65" />
    </LinearLayout>

    <!--
      工具栏面板：[返回] [章节标题] [编辑] [目录]
      高度 = contentPaddingTop（与沉浸顶栏占据完全相同位置）
      沉浸模式时 visibility=GONE，切出沉浸时 visibility=VISIBLE
    -->
    <LinearLayout
        android:id="@+id/toolbarPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:elevation="4dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/ibBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/tvChapterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/ibEditChapter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_open_in_new"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="编辑" />

        <ImageButton
            android:id="@+id/ibChapterList"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_sort"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="目录" />

    </LinearLayout>


    <!--
      沉浸底部信息栏：[进度%] [页码]
      高度由代码设定 = navBarHeight + 36dp（与 contentPaddingBottom 完全一致）
    -->
    <LinearLayout
        android:id="@+id/immersiveStatusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvImmersiveProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:alpha="0.65" />

        <TextView
            android:id="@+id/tvImmersiveChapterIdx"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:alpha="0.65" />
    </LinearLayout>

    <!-- 底部控制面板 -->
    <LinearLayout
        android:id="@+id/bottomControlOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceContainerHighest"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- 设置子面板 -->
        <LinearLayout
            android:id="@+id/panelSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <!-- 字号行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="字号"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontDec"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="52dp"
                    android:layout_height="36dp"
                    android:text="A-"
                    android:textSize="14sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />

                <TextView
                    android:id="@+id/tvFontSizeVal"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFontInc"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="52dp"
                    android:layout_height="36dp"
                    android:text="A+"
                    android:textSize="14sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="系统字体"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>

            <!-- 行距行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="行距"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSpacing1"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="密"
                    android:textSize="13sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSpacing2"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="适中"
                    android:textSize="13sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSpacing3"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="宽"
                    android:textSize="13sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSpacing4"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="超宽"
                    android:textSize="13sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />
            </LinearLayout>

            <!-- 背景色行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="背景"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <View android:id="@+id/vBgWhite"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:id="@+id/vBgCream"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:id="@+id/vBgWarm"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:id="@+id/vBgGreen"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:id="@+id/vBgWarmYellow"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:id="@+id/vBgNight"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <View android:id="@+id/vBgBlack"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- 翻页行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="翻页"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPageScroll"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="滚动"
                    android:textSize="13sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPageFlip"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="翻页"
                    android:textSize="13sp"
                    android:padding="0dp"
                    app:strokeColor="?attr/colorOutline" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:alpha="0.25"
                android:layout_marginBottom="4dp" />
        </LinearLayout>

        <!-- 亮度子面板 -->
        <LinearLayout
            android:id="@+id/panelBrightness"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_brightness"
                android:tint="?android:attr/textColorSecondary"
                android:alpha="0.5"
                android:contentDescription="低亮度" />

            <SeekBar
                android:id="@+id/sbBrightness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:max="100"
                android:progress="50" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_brightness"
                android:tint="?android:attr/textColorSecondary"
                android:contentDescription="高亮度" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.25" />

        <!-- 章节进度行（替代原来的上一章/下一章按钮） -->
        <TextView
            android:id="@+id/tvChapterProgress"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:alpha="0.25" />

        <!-- 底部四图标导航行 -->
        <LinearLayout
            android:id="@+id/bottomNavBar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/ibNavToc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_sort" android:tint="?attr/colorOnSurface"
                    android:contentDescription="目录" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="目录" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ibNavBrightness"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_brightness" android:tint="?attr/colorOnSurface"
                    android:contentDescription="亮度" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="亮度" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ibNavNight"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:id="@+id/ivNightIcon" android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_night" android:tint="?attr/colorOnSurface"
                    android:contentDescription="夜间" />
                <TextView android:id="@+id/tvNightLabel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="夜间" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ibNavSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_settings" android:tint="?attr/colorOnSurface"
                    android:contentDescription="设置" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="设置" android:textSize="11sp" android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
