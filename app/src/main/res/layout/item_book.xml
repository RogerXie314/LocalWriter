<?xml version="1.0" encoding="utf-8"?>
<!--
  书架 - 书籍封面卡片
  外观：仿真书皮，色彩丰富，含书脊、书名、作者、状态标签。
  固定高度 220dp，在主流手机两列网格中接近 2:3 书籍比例。
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBook"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_marginHorizontal="7dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="5dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp">

    <!-- 整体水平：书脊（左） + 封面内容（右） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- ── 书脊装饰条（半透明暗色） ── -->
        <View
            android:id="@+id/viewSpine"
            android:layout_width="10dp"
            android:layout_height="match_parent"
            android:background="#33000000"/>

        <!-- ── 封面主内容 ── -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="10dp">

            <!-- 状态标签（右上角） -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:textSize="8sp"
                android:textColor="@color/white"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:maxLines="1"/>

            <!-- 更多操作（状态标签下方） -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_below="@id/tvStatus"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="2dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#CCFFFFFF"
                android:padding="2dp"
                android:contentDescription="更多操作"/>

            <!-- 书名（垂直居中），左边预留空间让标题不压按钮 -->
            <TextView
                android:id="@+id/tvBookTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="32dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="5"
                android:ellipsize="end"/>

            <!-- 作者（底部倒数第二行） -->
            <TextView
                android:id="@+id/tvBookAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@id/tvWordCount"
                android:layout_marginBottom="3dp"
                android:textSize="10sp"
                android:textColor="#BBFFFFFF"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- 字数（底部最下行，在进度条上方） -->
            <TextView
                android:id="@+id/tvWordCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@id/viewReadProgress"
                android:layout_marginBottom="4dp"
                android:textSize="9sp"
                android:textColor="#99FFFFFF"/>

            <!-- 继续阅读（有阅读记录且 2 列模式显示，位于字数上方） -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueRead"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_above="@id/tvWordCount"
                android:layout_alignParentStart="true"
                android:paddingHorizontal="0dp"
                android:text="▶ 继续阅读"
                android:textSize="9sp"
                android:textColor="#DDFFFFFF"
                android:visibility="gone"/>

            <!-- 最底部：阅读进度条（有阅读记录时显示，紧贴底边） -->
            <View
                android:id="@+id/viewReadProgress"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_alignParentBottom="true"
                android:background="#66FFFFFF"
                android:visibility="gone"/>

        </RelativeLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>