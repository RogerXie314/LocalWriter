<?xml version="1.0" encoding="utf-8"?>
<!-- 书籍列表 Fragment 布局 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── 品牌大栏（替代 Activity Toolbar，兼顾品牌+操作） ── -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorPrimary"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="6dp"
            android:gravity="center_vertical">

            <!-- App icon -->
            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter"
                android:layout_marginEnd="10dp"
                android:contentDescription="LocalWriter"/>

            <!-- Brand text (two lines) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LocalWriter"
                    android:textColor="@color/white"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的书架"
                    android:textColor="#DDFFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <!-- 排序切换 -->
            <ImageButton
                android:id="@+id/ibSortBooks"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_sort"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="切换排序"/>

            <!-- 导入书籍 -->
            <ImageButton
                android:id="@+id/ibImportBook"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_import"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="导入书籍"/>

            <!-- 新建书籍 -->
            <ImageButton
                android:id="@+id/fabNewBook"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="新建书籍"/>

            <!-- 竖分割线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#55FFFFFF"
                android:layout_marginHorizontal="4dp"/>

            <!-- 设置 -->
            <ImageButton
                android:id="@+id/ibSettings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="设置"/>

            <!-- 锁定 -->
            <ImageButton
                android:id="@+id/ibLock"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_lock"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:padding="8dp"
                android:contentDescription="锁定"/>

        </LinearLayout>
    </LinearLayout>

    <!-- 书籍列表（在 header 下方独立占剩余高度） -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBooks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"/>

        <!-- 空状态居中显示 -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="52sp"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="书架还是空的"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击右上角 ＋ 创建第一本书"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
